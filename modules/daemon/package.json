{
  "name": "@cctop/daemon",
  "version": "0.3.0",
  "description": "Daemon process for cctop",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "start": "node dist/index.js",
    "test": "vitest run --reporter=default",
    "test:verbose": "vitest run --reporter=verbose",
    "test:fast": "vitest run --reporter=default tests/production-*.test.ts tests/npm-run-bug.test.ts",
    "test:minimal": "vitest run --config vitest.config.minimal.ts",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@cctop/shared": "^0.3.0",
    "chokidar": "^3.5.3"
  },
  "devDependencies": {
    "@types/node": "^20.14.9",
    "better-sqlite3": "^12.2.0",
    "typescript": "^5.5.3",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
