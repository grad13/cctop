{
  "name": "@cctop/cli",
  "version": "0.3.0",
  "description": "CCTOP CLI Module (v0.3.0)",
  "main": "dist/index.js",
  "bin": {
    "cctop": "./bin/cctop"
  },
  "scripts": {
    "build": "tsc",
    "start": "npm run build && node dist/index.js",
    "cctop": "./bin/cctop",
    "demo:create-db": "npm run build && node dist/demo/create-test-db.js",
    "demo:config": "npm run build && node dist/demo/demo-config-init.js",
    "demo:python-data": "npm run build && node dist/test/fixtures/demo-python-dummy-data.js",
    "test": "echo '⚠️  Direct test execution is disabled. Please use: npm run test:unit, test:functional:config/database/ui, test:integration, or test:interaction' && exit 1",
    "test:unit": "vitest run --reporter=default tests/unit --exclude=tests/unit/database/filter-processing-order.test.ts --exclude=tests/unit/utils/daemon-status-monitor.test.ts",
    "test:quick": "vitest run --reporter=default tests/unit/cli tests/unit/filters tests/unit/types tests/unit/ui tests/functional/config/config-loader-core.test.ts tests/functional/database/func000-compliance.test.ts tests/functional/database/staged-fetching.test.ts",
    "test:unit:safe": "vitest run --reporter=default tests/unit/cli tests/unit/filters tests/unit/types tests/unit/ui",
    "test:functional:config": "vitest run --reporter=default tests/functional/config/config-loader-core.test.ts tests/functional/config/cli-config.test.ts",
    "test:functional:database:safe": "vitest run --reporter=default tests/functional/database/func000-compliance.test.ts tests/functional/database/staged-fetching.test.ts",
    "test:functional:database": "vitest run --reporter=default tests/functional/database",
    "test:functional:ui": "vitest run --reporter=default tests/functional/ui tests/functional/data",
    "test:integration": "vitest run --reporter=default tests/integration",
    "test:interaction": "vitest run --reporter=default tests/interaction",
    "test:all": "vitest run --reporter=default",
    "test:watch": "vitest",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@cctop/shared": "file:../shared",
    "@types/blessed": "^0.1.21",
    "@types/sqlite3": "^3.1.8",
    "blessed": "^0.1.81",
    "chalk": "^4.1.2",
    "sqlite3": "^5.1.6",
    "string-width": "^5.1.2"
  },
  "devDependencies": {
    "@types/node": "^20.14.9",
    "typescript": "^5.5.3",
    "vitest": "^2.0.0"
  }
}
