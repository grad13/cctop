#!/usr/bin/env node

/**
 * cctop v0.1.0.0 エントリポイント
 * 機能1: 基本起動とメッセージ表示
 * 機能2: データベース初期化
 * 機能3: 設定システム
 * 機能4: ファイル監視
 */

const DatabaseManager = require('../src/database/database-manager');
const ConfigManager = require('../src/config/config-manager');
const FileMonitor = require('../src/monitors/file-monitor');
const EventProcessor = require('../src/monitors/event-processor');
const CLIDisplay = require('../src/ui/cli-display');

let dbManager = null;
let configManager = null;
let fileMonitor = null;
let eventProcessor = null;
let cliDisplay = null;

async function main() {
  try {
    if (process.env.NODE_ENV === 'test' || process.env.CCTOP_VERBOSE) {
      console.log('🚀 cctop v0.1.0.0 starting...');
      console.log('📁 Current directory:', process.cwd());
    }
    
    // コマンドライン引数のパース
    const cliArgs = {};
    const args = process.argv.slice(2);
    for (let i = 0; i < args.length; i++) {
      if (args[i] === '--config' && i + 1 < args.length) {
        cliArgs.config = args[i + 1];
        i++;
      } else if (args[i] === '--watch' && i + 1 < args.length) {
        cliArgs.watchPath = args[i + 1];
        i++;
      } else if (args[i] === '--db' && i + 1 < args.length) {
        cliArgs.dbPath = args[i + 1];
        i++;
      } else if (args[i] === '--max-lines' && i + 1 < args.length) {
        cliArgs.maxLines = args[i + 1];
        i++;
      }
    }
    
    // 機能3: 設定システム初期化
    configManager = new ConfigManager();
    const config = await configManager.initialize(cliArgs);
    
    // 機能2: データベース初期化（設定を使用）
    dbManager = new DatabaseManager(config.database.path);
    await dbManager.initialize();
    
    // 機能4: ファイル監視初期化
    const monitorConfig = {
      watchPaths: config.monitoring?.watchPaths || config.watchPaths || ["./"],
      ignored: config.monitoring?.excludePatterns || config.excludePatterns || [],
      depth: config.monitoring?.maxDepth || 10
    };
    
    fileMonitor = new FileMonitor(monitorConfig);
    
    // 機能5: Event Processor初期化（chokidar→DB統合）
    eventProcessor = new EventProcessor(dbManager);
    
    // 機能6: CLI Display初期化（ui001準拠）
    cliDisplay = new CLIDisplay(dbManager, config.display);
    
    // ファイル監視イベントをEvent Processorに接続
    fileMonitor.on('fileEvent', async (event) => {
      await eventProcessor.processFileEvent(event);
    });
    
    // Event Processorの処理完了イベントをCLI Displayに接続
    eventProcessor.on('eventProcessed', (result) => {
      cliDisplay.addEvent(result.recorded);
    });
    
    // 初期スキャン完了時の処理
    fileMonitor.on('ready', () => {
      eventProcessor.onInitialScanComplete();
    });
    
    fileMonitor.start();
    
    // CLI表示開始（すぐに画面をクリアして表示開始）
    cliDisplay.start();
    
    // 初期スキャン完了を待機
    await new Promise((resolve) => {
      fileMonitor.once('ready', resolve);
    });
    
    if (process.env.NODE_ENV === 'test' || process.env.CCTOP_VERBOSE) {
      console.log('✅ All systems working: entry, config, database, file monitoring, event processing, CLI display!');
      console.log('🎯 Starting real-time file activity monitor...');
    }
    
  } catch (error) {
    console.error('❌ Startup failed:', error.message);
    process.exit(1);
  }
}

// 基本的な終了処理
const shutdown = async () => {
  console.log('\n👋 cctop shutting down...');
  
  if (cliDisplay) {
    cliDisplay.stop();
  }
  
  if (fileMonitor) {
    await fileMonitor.stop();
  }
  
  if (eventProcessor) {
    eventProcessor.removeAllListeners();
  }
  
  if (dbManager) {
    await dbManager.close();
  }
  
  process.exit(0);
};

process.on('SIGINT', shutdown);
process.on('SIGTERM', shutdown);

// 未処理の例外をキャッチ
process.on('unhandledRejection', (reason, promise) => {
  console.error('Unhandled Rejection:', reason);
  process.exit(1);
});

main();