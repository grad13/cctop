{
  "name": "cctop",
  "version": "0.5.0",
  "description": "Agent work monitoring with real-time file tracking",
  "private": true,
  "workspaces": [
    "modules/*"
  ],
  "bin": {
    "cctop": "bin/cctop"
  },
  "scripts": {
    "install:all": "npm install",
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces",
    "daemon": "node bin/cctop-daemon",
    "cli": "node bin/cctop-cli",
    "dev": "npm run daemon & npm run cli",
    "demo": "node demo-ui.js",
    "simple": "node simple-demo.js"
  },
  "dependencies": {
    "blessed": "^0.1.81"
  },
  "devDependencies": {
    "@types/node": "^20.19.2",
    "typescript": "^5.5.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
