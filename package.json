{
  "name": "cctop",
  "version": "0.3.0",
  "description": "File system monitoring tool with daemon-cli architecture",
  "main": "dist/index.js",
  "bin": {
    "cctop": "./bin/cctop",
    "cctop-daemon": "./bin/cctop-daemon"
  },
  "scripts": {
    "start": "echo 'Please use npm run start:cli or npm run start:daemon'",
    "start:cli": "node modules/cli/dist/index.js",
    "start:daemon": "node modules/daemon/dist/index.js",
    "start:legacy": "node bin/cctop",
    "build": "npm run build:modules",
    "build:modules": "npm run build:shared && npm run build:daemon && npm run build:cli",
    "build:shared": "cd modules/shared && npm run build",
    "build:daemon": "cd modules/daemon && npm run build",
    "build:cli": "cd modules/cli && npm run build",
    "build:legacy": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:sequential": "node test/test-sequential.js",
    "test:watch": "vitest",
    "test:rdd": "vitest run --reporter=verbose",
    "test:e2e": "vitest run test/e2e/",
    "test:integration": "vitest run test/integration/",
    "rdd-verify": "node test/rdd-daily-verification.js",
    "postinstall": "node scripts/postinstall.js"
  },
  "keywords": [
    "monitoring",
    "filesystem",
    "events",
    "cli"
  ],
  "author": "grad13 <nyahha@gmail.com>",
  "license": "MIT",
  "dependencies": {
    "chalk": "^4.1.2",
    "chokidar": "^3.5.3",
    "sqlite3": "^5.1.6",
    "string-width": "^4.2.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.7",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4",
    "zod": "^3.25.67"
  },
  "engines": {
    "node": ">=14.0.0"
  }
}
