{
  "name": "cctop",
  "version": "0.1.0",
  "description": "File system monitoring tool with real-time event tracking",
  "main": "src/index.js",
  "bin": {
    "cctop": "./bin/cctop"
  },
  "scripts": {
    "start": "node bin/cctop",
    "test": "vitest run",
    "test:sequential": "node test/test-sequential.js",
    "test:watch": "vitest",
    "test:rdd": "vitest run --reporter=verbose",
    "postinstall": "node scripts/postinstall.js"
  },
  "keywords": [
    "monitoring",
    "filesystem",
    "events",
    "cli"
  ],
  "author": "grad13 <nyahha@gmail.com>",
  "license": "MIT",
  "dependencies": {
    "chalk": "^4.1.2",
    "chokidar": "^3.5.3",
    "sqlite3": "^5.1.6",
    "string-width": "^4.2.3"
  },
  "devDependencies": {
    "vitest": "^3.2.4",
    "zod": "^3.25.67"
  },
  "engines": {
    "node": ">=14.0.0"
  }
}
