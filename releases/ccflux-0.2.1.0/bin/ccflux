#!/usr/bin/env node

/**
 * cctop v0.2.0.0 - Code Change Top (File Monitoring Tool)
 * FUNC-104 CLI Interface compliant
 * FUNC-105 Local Setup Initialization compliant
 */

const DatabaseManager = require('../src/database/database-manager');
const ConfigManager = require('../src/config/config-manager');
const FileMonitor = require('../src/monitors/file-monitor');
const EventProcessor = require('../src/monitors/event-processor');
const CLIDisplay = require('../src/ui/cli-display');
const InotifyChecker = require('../src/system/inotify-checker');
const ViewerProcess = require('../src/ui/viewer-process');
const ProcessManager = require('../src/monitors/process-manager');

let dbManager = null;
let configManager = null;
let fileMonitor = null;
let eventProcessor = null;
let cliDisplay = null;

/**
 * --check-limits option handler (FUNC-104 compliant)
 */
/**
 * Show help message (FUNC-104 compliant)
 */
function showHelpMessage() {
  console.log(`cctop - Code Change Top (File Monitoring Tool)

Usage: cctop [options] [directory]

Options:
  Monitoring:
    -d, --dir <dir>       Directory to watch [default: current]
    -t, --timeout <sec>   Timeout in seconds

  Output:
    -v, --verbose         Enable verbose output
    -q, --quiet           Quiet mode (errors only)

  System:
    --check-limits        Check file watch limits

  Help:
    -h, --help            Show this help message
    --version             Show version information

Interactive Controls:
  Display modes:
    a - All events       u - Unique files      q - Quit

  Event filters:
    f - Find  c - Create  m - Modify  d - Delete  v - Move  r - Restore

Examples:
  cctop                   # Monitor current directory
  cctop src/              # Monitor src directory
  cctop --check-limits    # Check system limits`);
}

/**
 * Show version information (FUNC-104 compliant)
 */
function showVersionInfo() {
  const packageJson = require('../package.json');
  console.log(`cctop v${packageJson.version}`);
}

async function handleCheckLimits() {
  try {
    // 設定読み込み（inotify設定のため）
    const configManager = new ConfigManager();
    const config = await configManager.initialize({});
    const inotifyConfig = configManager.getInotifyConfig();
    
    // 現在の上限値を取得
    const currentLimit = await InotifyChecker.getCurrentLimit();
    
    // 充足性チェック
    const checkResult = InotifyChecker.checkLimitSufficiency(
      currentLimit, 
      inotifyConfig.requiredMaxUserWatches
    );
    
    // 結果表示
    console.log(InotifyChecker.formatCheckResult(checkResult));
    
  } catch (error) {
    console.error('Error checking inotify limits:', error.message);
    process.exit(1);
  }
}


async function main() {
  try {
    if (process.env.NODE_ENV === 'test' || process.env.CCTOP_VERBOSE) {
      console.log('🚀 cctop v0.1.0.0 starting...');
      console.log('📁 Current directory:', process.cwd());
    }
    
    // Command line argument parsing (FUNC-104 compliant)
    const cliArgs = {};
    const args = process.argv.slice(2);
    let checkLimitsOnly = false;
    let showHelp = false;
    let showVersion = false;
    
    for (let i = 0; i < args.length; i++) {
      const arg = args[i];
      
      // Help options
      if (arg === '-h' || arg === '--help') {
        showHelp = true;
      } else if (arg === '--version') {
        showVersion = true;
      }
      // Monitoring options
      else if ((arg === '-d' || arg === '--dir') && i + 1 < args.length) {
        cliArgs.watchPath = args[i + 1];
        i++;
      } else if ((arg === '-t' || arg === '--timeout') && i + 1 < args.length) {
        cliArgs.timeout = parseInt(args[i + 1]);
        i++;
      }
      // Output options
      else if (arg === '-v' || arg === '--verbose') {
        process.env.CCTOP_VERBOSE = 'true';
      } else if (arg === '-q' || arg === '--quiet') {
        cliArgs.quiet = true;
      }
      // System options
      else if (arg === '--check-limits') {
        checkLimitsOnly = true;
      } else if (arg === '--check-inotify') {
        checkLimitsOnly = true; // Same functionality as --check-limits
      }
      // Background Monitor options (FUNC-003)
      else if (arg === '--daemon') {
        cliArgs.daemonMode = true;
      } else if (arg === '--stop') {
        cliArgs.stopMonitor = true;
      }
      // Legacy support
      else if (arg === '--config' && i + 1 < args.length) {
        cliArgs.config = args[i + 1];
        i++;
      }
      // Position argument (directory)
      else if (!arg.startsWith('-')) {
        cliArgs.watchPath = arg;
      }
      // Unknown option error handling (FUNC-104 compliant)
      else {
        console.error(`Error: Unknown option: ${arg}`);
        console.error("Try 'cctop --help' for more information.");
        process.exit(1);
      }
    }
    
    // Handle help and version (FUNC-104 compliant)
    if (showHelp) {
      showHelpMessage();
      process.exit(0);
    }
    
    if (showVersion) {
      showVersionInfo();
      process.exit(0);
    }
    
    // --check-limits option processing
    if (checkLimitsOnly) {
      await handleCheckLimits();
      process.exit(0);
    }
    
    // 機能3: 設定システム初期化
    configManager = new ConfigManager();
    const config = await configManager.initialize(cliArgs);

    // Handle FUNC-003 background monitor commands
    if (cliArgs.stopMonitor) {
      const processManager = new ProcessManager(config);
      const result = await processManager.stopMonitor();
      if (result) {
        console.log('✅ Monitor process stopped');
      } else {
        console.log('ℹ️  No monitor process to stop');
      }
      process.exit(0);
    }


    if (cliArgs.daemonMode) {
      // Start monitor in daemon mode only
      const processManager = new ProcessManager(config);
      const monitorScript = require.resolve('../src/monitors/monitor-process.js');
      const pid = await processManager.startMonitor(monitorScript);
      console.log(`✅ Monitor started in background (PID: ${pid})`);
      process.exit(0);
    }
    
    // inotify上限チェック（起動時）
    const inotifyConfig = configManager.getInotifyConfig();
    if (InotifyChecker.shouldCheckLimits() && inotifyConfig.checkOnStartup) {
      const currentLimit = await InotifyChecker.getCurrentLimit();
      const checkResult = InotifyChecker.checkLimitSufficiency(
        currentLimit,
        inotifyConfig.requiredMaxUserWatches
      );
      
      // 不足時に警告表示
      if (checkResult.status === 'insufficient' && inotifyConfig.warnIfInsufficient) {
        console.warn(InotifyChecker.generateWarningMessage(
          checkResult.current,
          checkResult.required
        ));
        console.warn(''); // 空行
      }
    }
    
    // Default mode: Start instant viewer for immediate feedback (FUNC-206 compliant)
    // Use InstantViewer for < 100ms startup time
    const InstantViewer = require('../src/ui/instant-viewer');
    const viewer = new InstantViewer(config);
    
    // Handle graceful shutdown
    process.on('SIGINT', async () => {
      if (process.env.CCTOP_VERBOSE) {
        console.log('\n🛑 Received SIGINT, stopping...');
      }
      await viewer.stop();
      process.exit(0);
    });
    
    process.on('SIGTERM', async () => {
      if (process.env.CCTOP_VERBOSE) {
        console.log('\n🛑 Received SIGTERM, stopping...');
      }
      await viewer.stop();
      process.exit(0);
    });
    
    await viewer.start();
    
  } catch (error) {
    console.error('❌ Startup failed:', error.message);
    process.exit(1);
  }
}

// Signal handlers are now managed within ViewerProcess

// 未処理の例外をキャッチ
process.on('unhandledRejection', (reason, promise) => {
  console.error('Unhandled Rejection:', reason);
  process.exit(1);
});

main();