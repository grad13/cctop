{
  "version": "0.1.0",
  "monitoring": {
    "watchPaths": [
      "/Users/takuo-h/Workspace/Code/06-cctop"
    ],
    "excludePatterns": [
      "**/node_modules/**",
      "**/.git/**",
      "**/.*",
      "**/.cctop/**"
    ],
    "debounceMs": 100,
    "maxDepth": 10,
    "eventFilters": {
      "find": true,
      "create": true,
      "modify": true,
      "delete": true,
      "move": true,
      "restore": true
    },
    "inotify": {
      "requiredMaxUserWatches": 524288,
      "checkOnStartup": true,
      "warnIfInsufficient": true,
      "recommendedValue": 524288
    }
  },
  "database": {
    "path": "./.cctop/activity.db",
    "mode": "WAL"
  },
  "display": {
    "maxEvents": 20,
    "refreshRateMs": 100,
    "statusArea": {
      "maxLines": 3,
      "enabled": true,
      "scrollSpeed": 200,
      "updateInterval": 5000
    }
  }
}