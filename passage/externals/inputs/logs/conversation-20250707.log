⏺ 🧪 フィルター処理順序テストの書き方

  このようなテストには3つのアプローチがあります：

  1. データベース状態テスト（推奨）

  describe('Filter Processing Order', () => {
    it('should exclude deleted files when delete events are filtered', async () => {
      // 1. テストデータ作成
      const testData = [
        { file_id: 1, event_type: 'Create', timestamp: '2025-01-01 10:00:00' },
        { file_id: 1, event_type: 'Modify', timestamp: '2025-01-01 10:01:00' },
        { file_id: 1, event_type: 'Delete', timestamp: '2025-01-01 10:02:00' }, // 最新
        { file_id: 2, event_type: 'Create', timestamp: '2025-01-01 10:00:00' },
        { file_id: 2, event_type: 'Modify', timestamp: '2025-01-01 10:01:00' }, // 最新
      ];

      // 2. 期待値設定
      const withDeleteFilter = ['Create', 'Modify']; // Delete除外
      const withoutDeleteFilter = ['Create', 'Modify', 'Delete']; // 全て

      // 3. テスト実行
      const resultWithFilter = await adapter.getEvents({
        filters: withDeleteFilter,
        mode: 'unique'
      });
      const resultWithoutFilter = await adapter.getEvents({
        filters: withoutDeleteFilter,
        mode: 'unique'
      });

      // 4. 検証
      expect(resultWithFilter).toHaveLength(1); // file_id: 2のModifyのみ
      expect(resultWithoutFilter).toHaveLength(2); // file_id: 1のDelete + file_id: 2のModify
      expect(resultWithFilter[0].file_id).toBe(2); // 削除されていないファイルのみ
    });
  });

  2. スナップショットテスト

  it('should have consistent filter behavior', async () => {
    const result = await adapter.getEvents({
      filters: ['Create', 'Modify'],
      mode: 'unique'
    });

    // 結果の構造をスナップショットで保存
    expect(result).toMatchSnapshot();
  });

  3. 統合テスト

